<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
            http://www.liquibase.org/xml/ns/dbchangelog
            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <changeSet id="change-types-display_name-all-columns" author="Tobiasz">
        <modifyDataType tableName="course" columnName="display_name" newDataType="varchar(50)" />
        <modifyDataType tableName="subject" columnName="display_name" newDataType="varchar(100)" />
        <modifyDataType tableName="question" columnName="display_name" newDataType="varchar(150)" />
        <modifyDataType tableName="answer" columnName="display_name" newDataType="varchar(200)" />
    </changeSet>
</databaseChangeLog>